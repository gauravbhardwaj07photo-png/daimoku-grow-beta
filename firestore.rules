rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an administrator
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isAdmin == true;
    }

    // 1. Whitelist collection: holds pre-authorized email addresses and registration codes
    match /whitelist/{email} {
      // Checked anonymously on app load to verify registration codes and session access
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Settings collection: holds global campaign data (dates, targets, active list)
    match /settings/{docId} {
      // Anyone can read campaign goals and details to see active campaign status
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Users collection: holds user profile information (email, username, block, isAdmin role)
    match /users/{email} {
      // Authenticated users can read other profiles to populate leaderboards and lists
      allow read: if request.auth != null;
      // Users can only create or update their own profile; admins can write to all profiles
      allow create, update: if request.auth != null && (request.auth.token.email == email || isAdmin());
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // 4. User States collection: holds plant growth stats, streak, and accumulative daimoku hours
    match /userStates/{email} {
      // Users can only read/write their own state; admins can access all states for sync
      allow read, write: if request.auth != null && (request.auth.token.email == email || isAdmin());
    }

    // 5. Contributions collection: logs individual chanting sessions for the active campaign
    match /contributions/{contribId} {
      // Authenticated users can read contributions to display leaderboard summaries
      allow read: if request.auth != null;
      // Users can only create contributions under their own email address
      allow create: if request.auth != null && request.resource.data.userEmail == request.auth.token.email;
      // Only admins can update or delete contribution documents
      allow update, delete: if isAdmin();
    }
  }
}
